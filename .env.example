# ═══════════════════════════════════════
#  lore-engine — Environment Variables
#  절대 실제 값을 .env 파일에 커밋하지 마세요!
#  이 파일은 .env.example (템플릿용) 입니다.
# ═══════════════════════════════════════

# Riot Games API
RIOT_API_KEY=your_riot_api_key_here
RIOT_REGION=kr

# Nexon Open API (메이플스토리, FC Online, 퍼스트 디센던트)
# 하나의 애플리케이션으로 3개를 골랐다면 3항목 모두 동일한 키를 넣어도 무방합니다.
NEXON_MAPLESTORY_API_KEY=your_nexon_api_key_here
NEXON_FCONLINE_API_KEY=your_nexon_api_key_here
NEXON_TFD_API_KEY=your_nexon_api_key_here

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here

# Redis
REDIS_URL=redis://localhost:6379

# ChromaDB / Qdrant
VECTOR_DB_URL=http://localhost:8000

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# Evaluation Judge (Promptfoo)
# Gemini 사용 권장 (OpenAI API Key 불필요)
GEMINI_API_KEY=your_gemini_api_key_here
JUDGE_MODEL=gemini:gemini-1.5-flash

# Node
NODE_ENV=development
